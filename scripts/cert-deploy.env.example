# Konfiguration für scripts/deploy-haproxy-certs.sh
# Kopieren nach: scripts/cert-deploy.env (wird nicht ins Repo committet)
# Das Script läuft nur auf einem Server (z. B. AGT1), der Certbot und SSH-Zugang zu allen Knoten hat.

# Let's Encrypt Domain (z. B. agt-app.de)
CERT_DOMAIN=agt-app.de

# Pfad zu den Let's Encrypt Live-Zertifikaten (üblich: /etc/letsencrypt/live/$CERT_DOMAIN)
CERT_LE_DIR=/etc/letsencrypt/live/agt-app.de

# Komma-getrennte Liste der HAProxy-Knoten (Mesh-IPs, z. B. WireGuard)
CERT_SERVERS=172.20.0.1,172.20.0.2,172.20.0.3

# SSH-Benutzer auf den Zielservern
CERT_SSH_USER=root

# SSH-Key für keybasierte Anmeldung (ed25519 oder RSA)
# Nach ssh-keygen und ssh-copy-id auf alle Knoten verwenden.
CERT_SSH_KEY=/root/.ssh/id_ed25519

# Zielverzeichnis auf JEDEM Knoten: Ordner "ssl" im Projektverzeichnis.
# Muss dem Installationspfad entsprechen (z. B. /opt/agt-app-haproxy/ssl).
CERT_TARGET_DIR=/opt/agt-app-haproxy/ssl

# Container-Name des HAProxy-Containers (laut docker-compose: haproxy_gateway)
CERT_CONTAINER_NAME=haproxy_gateway

# Optional: E-Mail bei Fehlern/Erfolg (mail-Befehl muss installiert sein)
# CERT_ADMIN_EMAIL=admin@example.com
