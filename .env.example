# Node identity (set per server). Wird in HAProxy für localpeer und im Geo-Manager genutzt.
NODE_NAME=agt-1
NODE_PRIO=1

# WireGuard mesh IPs of all HAProxy/Geo-Manager nodes (comma-separated, Reihenfolge = agt-1, agt-2, agt-3). Wird im HAProxy-Entrypoint für Peers genutzt.
MESH_NODES=172.20.0.1,172.20.0.2,172.20.0.3

# Clusterweites Verbindungslimit (Überlastungsschutz): eine Zahl für das GESAMTE Cluster. Stick-Table mit Key "global", conn_cur über Peers summiert – ab diesem Wert 503. Pro-Backend-Rate-Limits (RPS) stehen fest in conf/haproxy.cfg (z. B. agt-get-api 50, sync-api 200).
CLUSTER_MAXCONN=200

# Anchor IPs: must resolve to DE/EU in geo map; used for plausibility check (comma-separated)
ANCHOR_IPS=8.8.8.8,8.8.4.4

# Geo-IP source: eine CSV-URL. Zwei Formate werden erkannt:
#   (1) network, country_iso_code (z. B. datasets/geoip2-ipv4 auf GitHub)
#   (2) ip_range_start, ip_range_end, country_code (z. B. sapics/ip-location-db, https://github.com/sapics/ip-location-db)
GEO_SOURCE_URL=https://raw.githubusercontent.com/datasets/geoip2-ipv4/main/data/geoip2-ipv4.csv
# Optional: zweite CSV gleichen Formats für IPv6; wird mit IPv4 zu einer geo.map zusammengeführt.
# Beispiel sapics (IPv4+IPv6): GEO_SOURCE_URL + GEO_SOURCE_IPV6_URL mit z. B. raw.githubusercontent.com/sapics/ip-location-db/main/geolite2-country/geolite2-country-ipv4.csv und ...-ipv6.csv
GEO_SOURCE_IPV6_URL=
# Optional: MaxMind-style two-file source (wenn gesetzt, kann GEO_SOURCE_URL entfallen; main.py nutzt beide Varianten).
GEO_BLOCKS_URL=
GEO_LOCATIONS_URL=

# Staged rollout delays (hours): Prio 2 = 48h after master, Prio 3 = 96h
STAGE_DELAY_PRIO2_HOURS=48
STAGE_DELAY_PRIO3_HOURS=96

# Pull interval: how often to update IP lists (hours)
FETCH_INTERVAL_HOURS=24

# Retries on fetch/validation failure; delay between retries (seconds)
FETCH_RETRIES=3
FETCH_RETRY_DELAY_SEC=60

# Optional: IPv6 blocks CSV (same format as GeoLite2); merged into geo.map
GEO_BLOCKS_IPV6_URL=

# Reject new map if size < threshold * previous size (e.g. 0.9 = 10% smaller)
SIZE_DEVIATION_THRESHOLD=0.9

# Resource throttling: avoid CPU spikes on weak nodes (4 cores, 8GB shared with APIs/Yugabyte/Redis)
# BUILD_NICE_LEVEL: process nice (10 = lower priority; higher = more yielding)
# BUILD_CHUNK_SIZE: process N blocks/lines per chunk, then sleep
# BUILD_SLEEP_AFTER_CHUNK_MS: ms to sleep after each chunk (prefer 10 min longer build over 20s spike)
BUILD_NICE_LEVEL=10
BUILD_CHUNK_SIZE=5000
BUILD_SLEEP_AFTER_CHUNK_MS=50

# Mail notifications (e.g. mailcow) – only on final failure after retries
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=geo-manager@example.com
MAIL_TO=admin@example.com

# Cluster health: interval (hours, 168 = weekly), timeout per node (seconds)
CLUSTER_HEALTH_INTERVAL_HOURS=168
CLUSTER_HEALTH_TIMEOUT_SEC=5

# HAProxy Stats-Dashboard (Port 56708)
# Zugangsdaten werden NICHT in der Config hinterlegt, sondern nur hier per ENV gesetzt.
# Unbedingt pro Umgebung eigene, starke Passwörter vergeben.
STATS_USER=admin
STATS_PASSWORD=change-me

# Geo-Manager HTTP port (status, health, cluster, metrics)
GEO_STATUS_PORT=8080

# cert-manager: optional In-Cluster-Zertifikats-Rollout
# Gleiche docker-compose.yaml auf allen Knoten; Rolle des Zertifikats-Masters
# wird über CERT_IS_MASTER gesteuert. Genau ein Knoten muss CERT_IS_MASTER=true
# gesetzt haben, alle anderen false. Bei Mehrfach-Master schaltet der Rollout
# automatisch ab.
CERT_IS_MASTER=false

# Certbot/Let's Encrypt: Damit die Symlinks in live/<domain>/ (→ archive/<domain>/) im
# Container auflösen, das BASIS-Verzeichnis mounten (nicht nur live/domain). Dann sehen
# die Pfade im Container so aus: /certs/live/<domain>/fullchain.pem
CERT_LE_BASE_HOST=/etc/letsencrypt
# Fallback, wenn CERT_LE_BASE_HOST nicht gesetzt: nur live/domain mounten (Symlinks
# funktionieren dann nicht – nur wenn echte Dateien in live/domain liegen).
# CERT_LE_DIR_HOST=/etc/letsencrypt/live/example.org

# Pfade zu Certbot-Zertifikaten IM CONTAINER (/certs = Mount von CERT_LE_BASE_HOST).
# Bei CERT_LE_BASE_HOST=/etc/letsencrypt: /certs/live/<domain>/...
CERT_SOURCE_FULLCHAIN=/certs/live/agt-app.de/fullchain.pem
CERT_SOURCE_PRIVKEY=/certs/live/agt-app.de/privkey.pem

# Zielpfad für das von cert-manager erzeugte HAProxy-PEM im Container.
# Dieser Pfad muss mit dem von HAProxy genutzten Pfad übereinstimmen (siehe docker-compose).
CERT_TARGET_PEM_PATH=/etc/ssl/certs/haproxy.pem

# Port für den cert-manager HTTP-Statusdienst (nur im Mesh/Internetzugriff).
CERT_STATUS_PORT=8081

# Verzögerung (Staged Rollout) für Zertifikatsübernahme auf Followern (Stunden).
CERT_STAGE_DELAY_PRIO2_HOURS=1
CERT_STAGE_DELAY_PRIO3_HOURS=2

# Poll-Intervall für Follower (Sekunden), wie oft der Master nach neuem Zertifikat gefragt wird.
CERT_POLL_INTERVAL_SECONDS=300

# Gemeinsamer Pre-Shared-Key für den Zertifikats-Cluster (optional),
# kann später für HMAC/Signaturen genutzt werden. Nicht ins Repo committen.
CERT_CLUSTER_KEY=

# Beispiel-Konfigurationen für Master/Follower (pro Knoten eigene .env anlegen)
#
# --- agt-1 (Master, Zertifikats-Master + Geo-Master) ---
# NODE_NAME=agt-1
# NODE_PRIO=1
# CERT_IS_MASTER=true
# MESH_NODES=172.20.0.1,172.20.0.2,172.20.0.3
# CLUSTER_MAXCONN=200
# ANCHOR_IPS=8.8.8.8,8.8.4.4
# GEO_SOURCE_URL=https://raw.githubusercontent.com/datasets/geoip2-ipv4/main/data/geoip2-ipv4.csv
#
# Pfade zu Let's-Encrypt-Zertifikaten auf dem Host (Certbot-Standardpfad):
# CERT_LE_DIR_HOST=/etc/letsencrypt/live/example.org
# CERT_SOURCE_FULLCHAIN=/certs/fullchain.pem
# CERT_SOURCE_PRIVKEY=/certs/privkey.pem
#
# --- agt-2 (Follower, Prio 2) ---
# NODE_NAME=agt-2
# NODE_PRIO=2
# CERT_IS_MASTER=false
# MESH_NODES=172.20.0.1,172.20.0.2,172.20.0.3
#
# --- agt-3 (Follower, Prio 3) ---
# NODE_NAME=agt-3
# NODE_PRIO=3
# CERT_IS_MASTER=false
# MESH_NODES=172.20.0.1,172.20.0.2,172.20.0.3
