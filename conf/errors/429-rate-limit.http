HTTP/1.0 429 Too Many Requests
Cache-Control: no-cache
Connection: close
Content-Type: application/json

{
  "error": "rate_limit_exceeded",
  "http_status": 429,
  "category": "edge_rate_limit",
  "message": "Zu viele Anfragen. Bitte versuchen Sie es spaeter erneut.",
  "hint": "Rate limit per IP on HAProxy edge (cluster-wide). If you are a legitimate user, please wait and retry.",
  "details": "Request rate for this IP has exceeded the configured limit for this endpoint. This limit is enforced globally across all cluster nodes."
}
