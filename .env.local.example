# Lokaler Test (ein Knoten, Master). Kopiere nach .env.

NODE_NAME=agt-1
NODE_PRIO=1
MESH_NODES=

# Ohne Anchor-IPs (leer) entfällt der Anchor-Check – für lokalen Test ausreichend.
ANCHOR_IPS=

# Lokale Datei (Container oft ohne Internet). Einmal auf Host:
#   curl -o conf/test-data/geoip2-ipv4.csv https://raw.githubusercontent.com/datasets/geoip2-ipv4/main/data/geoip2-ipv4.csv
GEO_SOURCE_URL=file:///data/geoip2-ipv4.csv

# Erster Fetch sofort; danach alle 3 Minuten (nur für Test – Produktion z. B. 24)
FETCH_INTERVAL_HOURS=0.05

# Optional: gleiche Defaults wie .env.example
STAGE_DELAY_PRIO2_HOURS=48
STAGE_DELAY_PRIO3_HOURS=96
SIZE_DEVIATION_THRESHOLD=0.9
BUILD_NICE_LEVEL=10
BUILD_CHUNK_SIZE=5000
BUILD_SLEEP_AFTER_CHUNK_MS=50
